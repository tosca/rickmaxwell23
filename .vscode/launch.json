    "version": "0.2.0",
    "configurations": [
        {
            "name": ".Net/C++ Debugger",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickProcess}"
        },
        {
            "type": "msedge",
            "request": "launch",
            "name": "Launch rickmaxwell.com",
            "url": "http://localhost:8000",
            "webRoot": "${workspaceFolder}",
            "preLaunchTask": "start-web-server"
        }
    ]
}   